{
  "manifest_version": 3,
  "name": "DSASHEET",
  "description": "directly add question info to your dsa sheet for tracking prep..",
  "version": "1.0.0",
  "action": {
    "default_popup": "main.html",
    "default_icon": "images/extLogo.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "tabs","scripting"]
}